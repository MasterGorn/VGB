# Video Games Battle — variables d'environnement
# Copier vers .env.local (dev) ou dashboard Vercel (prod).

# MongoDB Atlas (obligatoire)
MONGODB_URI=

# NextAuth (obligatoire)
# openssl rand -base64 32
NEXTAUTH_SECRET=

# URL publique sans slash final
# Local : http://localhost:3000
# Prod  : https://www.videogamesbattle.com
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
